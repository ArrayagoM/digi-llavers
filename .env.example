# ── Servidor ──────────────────────────────────────────────
PORT=3000
BASE_URL=http://localhost:3000   # En Vercel: https://tu-app.vercel.app

# ── Almacenamiento ────────────────────────────────────────
STORAGE_DRIVER=local             # "local" (dev) | "supabase" (prod)
UPLOAD_DIR=./uploads             # Solo para driver "local"

# ── Supabase (completar para producción) ──────────────────
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_KEY=eyJ...   ← service_role key (no la anon)

# ── Archivos ──────────────────────────────────────────────
MAX_FILE_SIZE_MB=50
ALLOWED_MIMETYPES=audio/ogg,audio/mpeg,audio/wav,audio/mp4,video/mp4,video/webm,video/quicktime
